version: 2

project_name: {{TOOL_NAME}}

before:
  hooks:
    - go mod tidy

builds:
  - env:
      - CGO_ENABLED=0
    goos:
      - linux
      - darwin
      - windows
    goarch:
      - amd64
      - arm64
    ldflags:
      - -s -w -X {{MODULE_PATH}}/cmd.Version={{.Version}}
    main: .

archives:
  - formats: [tar.gz]
    name_template: "{{ .ProjectName }}_{{ .Os }}_{{ .Arch }}"
    format_overrides:
      - goos: windows
        formats: [zip]

checksum:
  name_template: checksums.txt

changelog:
  sort: asc
  filters:
    exclude:
      - "^docs:"
      - "^test:"
      - "^chore:"

brews:
  - name: {{TOOL_NAME}}
    repository:
      owner: {{GITHUB_USER}}
      name: homebrew-tap
      token: "{{ .Env.HOMEBREW_TAP_TOKEN }}"
    directory: Formula
    homepage: https://github.com/{{GITHUB_USER}}/{{TOOL_NAME}}
    description: {{DESCRIPTION}}
    license: MIT
    install: |
      bin.install "{{TOOL_NAME}}"
    test: |
      system "#{bin}/{{TOOL_NAME}}", "version"

release:
  github:
    owner: {{GITHUB_USER}}
    name: {{TOOL_NAME}}
  draft: false
  prerelease: auto
