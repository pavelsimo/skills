[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
name = "{{TOOL_NAME}}"
dynamic = ["version"]
description = "{{DESCRIPTION}}"
readme = "README.md"
requires-python = ">=3.11"
license = { text = "MIT" }
authors = [{ name = "{{GITHUB_USER}}" }]
keywords = ["cli"]
classifiers = [
    "Development Status :: 3 - Alpha",
    "Environment :: Console",
    "Intended Audience :: Developers",
    "License :: OSI Approved :: MIT License",
    "Programming Language :: Python :: 3",
    "Programming Language :: Python :: 3.11",
    "Programming Language :: Python :: 3.12",
    "Programming Language :: Python :: 3.13",
]
dependencies = [
    "typer>=0.15",
    "rich>=13.0",
]

[project.scripts]
{{TOOL_NAME}} = "{{MODULE_NAME}}.cli:app"

[project.urls]
Homepage = "https://{{GITHUB_USER}}.github.io/{{TOOL_NAME}}"
Repository = "https://github.com/{{GITHUB_USER}}/{{TOOL_NAME}}"
Issues = "https://github.com/{{GITHUB_USER}}/{{TOOL_NAME}}/issues"

[dependency-groups]
dev = [
    "pytest>=8.0",
    "pytest-cov>=5.0",
    "mypy>=1.10",
    "ruff>=0.6",
]

[tool.hatch.version]
path = "{{MODULE_NAME}}/__init__.py"

[tool.ruff]
line-length = 120
target-version = "py311"

[tool.ruff.lint]
select = ["E", "F", "I", "UP", "B", "SIM"]
ignore = ["E501"]

[tool.ruff.lint.per-file-ignores]
"tests/**" = ["S101"]

[tool.mypy]
strict = true
python_version = "3.11"
files = ["{{MODULE_NAME}}"]

[tool.pytest.ini_options]
testpaths = ["tests"]
addopts = "--cov={{MODULE_NAME}} --cov-report=term-missing"

[tool.coverage.run]
branch = true
source = ["{{MODULE_NAME}}"]

[tool.coverage.report]
fail_under = 70
show_missing = true
