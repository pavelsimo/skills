from __future__ import annotations

import os
import sys
from typing import Optional

import typer
from rich.console import Console

from {{MODULE_NAME}} import __version__

app = typer.Typer(
    name="{{TOOL_NAME}}",
    help="{{DESCRIPTION}}",
    no_args_is_help=True,
    rich_markup_mode="rich",
    context_settings={"help_option_names": ["-h", "--help"]},
)

out = Console()
err = Console(stderr=True)


def _version_callback(value: bool) -> None:
    if value:
        out.print(f"{{TOOL_NAME}} {__version__}")
        raise typer.Exit()


@app.callback()
def main(
    _version: Optional[bool] = typer.Option(
        None,
        "--version",
        "-V",
        callback=_version_callback,
        is_eager=True,
        help="Show version and exit.",
    ),
    verbose: bool = typer.Option(False, "--verbose", "-v", help="Enable verbose output.", is_eager=False),
    quiet: bool = typer.Option(False, "--quiet", "-q", help="Suppress non-essential output."),
    json_output: bool = typer.Option(False, "--json", help="Output results as JSON."),
    no_color: bool = typer.Option(
        False,
        "--no-color",
        help="Disable ANSI color output.",
        envvar="NO_COLOR",
    ),
    dry_run: bool = typer.Option(False, "--dry-run", "-n", help="Preview changes without applying them."),
    no_input: bool = typer.Option(False, "--no-input", help="Disable interactive prompts."),
) -> None:
    """{{DESCRIPTION}}"""
    if no_color or os.environ.get("NO_COLOR"):
        # Re-create consoles without color when flag is set at callback time.
        global out, err  # noqa: PLW0603
        out = Console(no_color=True)
        err = Console(stderr=True, no_color=True)


@app.command("version")
def cmd_version() -> None:
    """Show the version and exit."""
    out.print(f"{{TOOL_NAME}} {__version__}")


def _is_tty() -> bool:
    return sys.stdin.isatty()
