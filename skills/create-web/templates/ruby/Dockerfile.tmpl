# Build stage: compile assets, install gems, precompile bootsnap
FROM ruby:{{RUBY_VERSION}}-slim AS build

RUN apt-get update -qq && \
    apt-get install --no-install-recommends -y \
      build-essential \
      libsqlite3-dev \
      git \
      curl && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /rails

# Install gems first (cached layer)
COPY Gemfile Gemfile.lock ./
RUN bundle install --jobs 4 --retry 3 && \
    rm -rf ~/.bundle/ "${BUNDLE_PATH}"/ruby/*/cache "${BUNDLE_PATH}"/ruby/*/bundler/gems/*/.git

# Copy application code
COPY . .

# Precompile bootsnap for faster boot
RUN bundle exec bootsnap precompile app/ lib/

# Precompile assets (SECRET_KEY_BASE_DUMMY avoids credentials requirement)
RUN SECRET_KEY_BASE_DUMMY=1 ./bin/rails assets:precompile

# Final stage: minimal runtime image
FROM ruby:{{RUBY_VERSION}}-slim AS final

# Install runtime dependencies only
RUN apt-get update -qq && \
    apt-get install --no-install-recommends -y \
      libsqlite3-0 \
      libjemalloc2 \
      curl && \
    rm -rf /var/lib/apt/lists/*

# Use jemalloc for lower memory usage and better performance
ENV LD_PRELOAD="/usr/lib/$(uname -m)-linux-gnu/libjemalloc.so.2" \
    RAILS_ENV="production" \
    BUNDLE_DEPLOYMENT="1" \
    BUNDLE_PATH="/usr/local/bundle" \
    BUNDLE_WITHOUT="development:test"

# Create non-root user for security
RUN groupadd --system --gid 1000 rails && \
    useradd rails --uid 1000 --gid 1000 --create-home --shell /bin/bash

WORKDIR /rails

# Copy built artifacts from build stage
COPY --from=build --chown=rails:rails /usr/local/bundle /usr/local/bundle
COPY --from=build --chown=rails:rails /rails /rails

# Create writable directories
RUN mkdir -p storage log tmp/pids && chown -R rails:rails storage log tmp

USER rails:rails

EXPOSE 3000

ENTRYPOINT ["/rails/bin/docker-entrypoint"]
CMD ["./bin/thrust", "./bin/rails", "server"]
