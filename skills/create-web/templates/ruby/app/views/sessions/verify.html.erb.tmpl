<div class="auth-container">
  <div class="auth-card">
    <h1 class="auth-title">Check your email</h1>
    <p class="auth-subtitle">We sent a 6-digit code to your email address. Enter it below to sign in.</p>

    <%= form_with url: confirm_session_path, class: "auth-form" do |f| %>
      <div class="field">
        <%= f.label :code, "Verification code" %>
        <%= f.text_field :code,
              autofocus: true,
              autocomplete: "one-time-code",
              inputmode: "numeric",
              pattern: "[0-9]{6}",
              maxlength: 6,
              placeholder: "123456",
              required: true %>
      </div>

      <%= f.submit "Sign in", class: "btn btn--primary" %>
    <% end %>

    <p class="auth-footer">
      <%= link_to "Use a different email address", new_session_path %>
    </p>
  </div>
</div>
