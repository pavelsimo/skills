require_relative "boot"

require "rails/all"

Bundler.require(*Rails.groups)

module {{APP_CLASS}}
  class Application < Rails::Application
    config.load_defaults 8.0

    config.autoload_lib(ignore: %w[assets tasks])

    # Use UUID (v4) primary keys for all generated models
    config.generators.orm :active_record, primary_key_type: :uuid

    # Use Solid Queue for background jobs (database-backed, no Redis)
    config.active_job.queue_adapter = :solid_queue

    # Default timezone and locale
    config.time_zone = "UTC"
    config.i18n.default_locale = :en

    # Use Solid Cable for ActionCable (database-backed WebSockets)
    config.action_cable.cable = { adapter: "solid_cable" }
  end
end
